# Fission Oracle Keeper — Environment
LEDGER_API_URL=http://localhost:2975

# Party — populate from the bootstrap script output
ORACLE_PARTY=

# JWT for the oracle party. In LocalNet, mint via Keycloak with appropriate scope.
ORACLE_JWT_TOKEN=

# Asset to track
ASSET_CODE=USYC

# Hashnote NAV API (mainnet). For testnet use https://usyc.dev.hashnote.com/api/price-reports
USYC_API_URL=https://usyc.hashnote.com/api/price-reports

# How often to poll the NAV source.
POLL_INTERVAL_MS=60000
