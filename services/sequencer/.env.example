# Fission Batch Sequencer — Environment
LEDGER_API_URL=http://localhost:2975

# Party — populate from the bootstrap script output
SEQUENCER_PARTY=

# JWT for the sequencer party
SEQUENCER_JWT_TOKEN=

# How often to settle pending swaps. Lower = lower latency, higher = more batching.
BATCH_INTERVAL_MS=3000
MAX_BATCH_SIZE=100
